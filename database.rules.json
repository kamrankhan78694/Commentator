{
  "rules": {
    "comments": {
      "$urlHash": {
        ".read": true,
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['text', 'author', 'timestamp']) || newData.hasChildren(['content', 'author', 'timestamp'])",
        "text": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 5000"
        },
        "content": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 5000"
        },
        "author": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },
        "timestamp": {
          ".validate": "newData.isNumber() || newData.isString()"
        },
        "votes": {
          ".validate": "newData.isNumber()"
        },
        "nftId": {
          ".validate": "newData.isString() || newData.isNumber()"
        },
        "ipfsUrl": {
          ".validate": "newData.isString()"
        },
        "isNFT": {
          ".validate": "newData.isBoolean()"
        },
        "parentId": {
          ".validate": "newData.isString()"
        },
        "userId": {
          ".validate": "newData.isString()"
        },
        "url": {
          ".validate": "newData.isString()"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() === 'published' || newData.val() === 'deleted' || newData.val() === 'flagged')"
        },
        "isEdited": {
          ".validate": "newData.isBoolean()"
        },
        "editedAt": {
          ".validate": "newData.isNumber() || newData.val() == null"
        },
        "deletedAt": {
          ".validate": "newData.isNumber() || newData.val() == null"
        },
        "flags": {
          ".validate": "newData.hasChildren()"
        },
        "flagCount": {
          ".validate": "newData.isNumber()"
        },
        "email": {
          ".validate": "newData.isString()"
        },
        "website": {
          ".validate": "newData.isString()"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        }
      }
    },
    "users": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId",
        ".validate": "newData.hasChildren(['displayName', 'createdAt'])",
        "displayName": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50"
        },
        "email": {
          ".validate": "newData.isString()"
        },
        "walletAddress": {
          ".validate": "newData.isString()"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "lastActive": {
          ".validate": "newData.isNumber()"
        }
      }
    },
    "sessions": {
      "$sessionId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['userId', 'createdAt']) || newData.hasChildren(['userId', 'startTime'])",
        "userId": {
          ".validate": "newData.isString() && auth.uid == newData.val()"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "startTime": {
          ".validate": "newData.isNumber() || newData.val() == null"
        },
        "lastActivity": {
          ".validate": "newData.isNumber() || newData.val() == null"
        },
        "endTime": {
          ".validate": "newData.isNumber() || newData.val() == null"
        },
        "userAgent": {
          ".validate": "newData.isString()"
        },
        "ipAddress": {
          ".validate": "newData.isString()"
        },
        "status": {
          ".validate": "newData.isString()"
        },
        "referrer": {
          ".validate": "newData.isString()"
        },
        "timestamp": {
          ".validate": "newData.isNumber()"
        }
      }
    }
  }
}